              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password_hash\": \"123456\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"Login correcto\", function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data).to.have.property(\"access_token\");",
                  "});",
                  "",
                  "if (json.success && json.data?.access_token) {",
                  "  pm.environment.set(\"token\", json.data.access_token);",
                  "  pm.environment.set(\"usuario_sistema_id\", String(json.data.user.id));",
                  "  pm.environment.set(\"username\", json.data.user.username);",
                  "  pm.environment.set(\"rol_sistema\", json.data.user.rol_sistema);",
                  "}"
                ]
              }
            }
          ],
          "auth": {
            "type": "noauth"
          }
        }
      ]
    },
