            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tabla_afectada\": \"libro\",\n  \"id_registro\": 1,\n  \"accion\": \"INSERT\",\n  \"usuario_sistema\": \"admin\",\n  \"valor_anterior\": null,\n  \"valor_nuevo\": \"Registro creado\"\n}"
            },
            "url": "{{base_url}}/auditoria"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"Respuesta exitosa\", function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "if (json.success && json.data?.id_auditoria) {",
                  "  pm.environment.set(\"auditoria_id\", String(json.data.id_auditoria));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH /auditoria/:id",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"valor_nuevo\": \"Registro actualizado\"\n}"
            },
            "url": "{{base_url}}/auditoria/{{auditoria_id}}"
          }
        },
        {
          "name": "DELETE /auditoria/:id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/auditoria/{{auditoria_id}}"
          }
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-captura de variables para Biblioteca Local",
          "// Este script corre despues de cada request de la coleccion.",
          "let json = null;",
          "",
          "try {",
          "  json = pm.response.json();",
          "} catch (error) {",
          "  json = null;",
          "}",
          "",
          "const setEnv = (key, value) => {",
          "  if (value !== undefined && value !== null && value !== \"\") {",
          "    pm.environment.set(key, String(value));",
          "    console.log(`Variable ${key} = ${value}`);",
          "  }",
          "};",
          "",
          "const firstRecord = (value) => {",
          "  if (Array.isArray(value)) {",
          "    return value[0] || null;",
          "  }",
          "",
          "  return value || null;",
          "};",
          "",
          "const payload = json && Object.prototype.hasOwnProperty.call(json, \"data\") ? json.data : json;",
          "const record = firstRecord(payload);",
          "",
          "// Login: token y datos del usuario autenticado",
          "if (payload && payload.access_token) {",
          "  setEnv(\"token\", payload.access_token);",
          "  setEnv(\"usuario_sistema_id\", payload.user && payload.user.id);",
          "  setEnv(\"username\", payload.user && payload.user.username);",
          "  setEnv(\"rol_sistema\", payload.user && payload.user.rol_sistema);",
          "}",
          "",
          "// IDs principales: funciona con GET lista, GET por ID y POST creado",
          "if (record) {",
          "  setEnv(\"rol_id\", record.id_rol);",
          "  setEnv(\"usuario_sistema_id\", record.id_usuario_sistema);",
          "  setEnv(\"usuario_id\", record.id_usuario);",
          "  setEnv(\"categoria_id\", record.id_categoria);",
          "  setEnv(\"editorial_id\", record.id_editorial);",
          "  setEnv(\"autor_id\", record.id_autor);",
          "  setEnv(\"libro_id\", record.id_libro);",
          "  setEnv(\"ejemplar_id\", record.id_ejemplar);",
          "  setEnv(\"prestamo_id\", record.id_prestamo);",
          "  setEnv(\"auditoria_id\", record.id_auditoria);",
          "}",
          "",
          "// Relaciones utiles cuando una respuesta trae datos anidados o llaves foraneas",
          "if (record) {",
          "  setEnv(\"rol_id\", record.id_rol);",
          "  setEnv(\"usuario_id\", record.id_usuario);",
          "  setEnv(\"usuario_sistema_id\", record.id_usuario_sistema);",
          "  setEnv(\"libro_id\", record.id_libro);",
          "  setEnv(\"categoria_id\", record.id_categoria);",
          "  setEnv(\"editorial_id\", record.id_editorial);",
          "}",
          "",
          "pm.test(\"Respuesta procesada para variables automaticas\", function () {",
          "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 204, 400, 401, 404]);",
          "});"
        ]
      }
    }
  ]
}