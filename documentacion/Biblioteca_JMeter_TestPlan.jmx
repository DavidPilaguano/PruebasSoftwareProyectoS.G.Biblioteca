        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="11 - GET dashboard stats" enabled="true">
          <stringProp name="HTTPSampler.path">/libros/dashboard/stats</stringProp>
